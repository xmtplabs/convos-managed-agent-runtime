{
  "name": "convos-agents-pool",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx --env-file=.env --watch src/index.ts",
    "start": "tsx src/index.ts",
    "ngrok": "ngrok http 3001 --url=convos-local-pool.ngrok.app",
    "test": "tsx --env-file=.env --test src/**/*.test.ts",
    "db:migrate": "tsx --env-file=.env src/db/migrate.ts",
    "datadog:test": "tsx --env-file=.env scripts/test-datadog.ts",
    "agentmail:test": "tsx --env-file=.env scripts/test-agentmail.ts",
    "openrouter:test": "tsx --env-file=.env scripts/test-openrouter.ts",
    "sms:audit": "tsx --env-file=.env scripts/sms-pool-audit.ts",
    "telnyx:test": "tsx --env-file=.env scripts/telnyx-test.ts",
    "telnyx:sms-send": "tsx --env-file=.env scripts/telnyx-sms-send.ts",
    "telnyx:sms-test": "tsx --env-file=.env scripts/telnyx-sms-test.ts",
    "railway:test": "tsx --env-file=.env scripts/test-railway.ts",
    "stripe:listen": "stripe listen --forward-to http://localhost:3001/webhooks/stripe",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "datadog-metrics": "0.12.1",
    "drizzle-orm": "0.45.1",
    "express": "5.2.1",
    "nanoid": "5.1.6",
    "pg": "8.18.0",
    "stripe": "17.7.0",
    "svix": "1.89.0"
  },
  "devDependencies": {
    "@types/express": "5.0.6",
    "@types/node": "22.19.11",
    "@types/pg": "8.16.0",
    "drizzle-kit": "0.31.9",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  }
}
