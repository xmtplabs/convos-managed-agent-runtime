# Pool Manager — unified config (pool + services merged)
PORT=3001
POOL_API_KEY=your-shared-pool-secret

# Database (single unified DB)
DATABASE_URL=postgresql://...

# Pool behavior
POOL_STUCK_TIMEOUT_MS=600000
TICK_INTERVAL_MS=30000

# Pool URL — auto-derived from RAILWAY_PUBLIC_DOMAIN in production.
# Only set for local dev or when RAILWAY_PUBLIC_DOMAIN isn't available.
POOL_URL=http://localhost:3001
# Optional: override auto-detected environment name
POOL_ENVIRONMENT=

# Railway (sharded — one project per agent)
RAILWAY_TEAM_ID=your-railway-team-id
RAILWAY_API_TOKEN=your-railway-api-token
RAILWAY_RUNTIME_IMAGE=ghcr.io/xmtplabs/convos-runtime:production

# OpenRouter
OPENROUTER_MANAGEMENT_KEY=sk-or-v1-...
OPENROUTER_KEY_LIMIT=20

# AgentMail — pool holds the key, proxies email calls from instances
AGENTMAIL_API_KEY=am_...
AGENTMAIL_DOMAIN=mail.convos.org

# Telnyx — pool holds the key, proxies SMS calls from instances
TELNYX_API_KEY=KEY...
TELNYX_MESSAGING_PROFILE_ID=your-profile-id

# Instance passthrough vars (set on each runtime container directly)
XMTP_ENV=dev

# Optional
NOTION_API_KEY=
TEMPLATE_SITE_URL=https://assistants.convos.org
TEMPLATE_SITE_ORIGINS=http://localhost:3000
