{
  "lowCreditThreshold": 0.50,
  "overloadedPatterns": [
    "temporarily overloaded",
    "overloaded_error",
    "service unavailable",
    "service temporarily unavailable",
    "high demand",
    "error code: 529",
    "error code: 503"
  ],
  "rateLimitPatterns": [
    "error code: 429",
    "rate limit exceeded",
    "please retry after"
  ],
  "creditPatterns": [
    "limit exceeded",
    "openrouter.ai/settings",
    "afford",
    "error code: 402",
    "payment required"
  ],
  "contextOverflowPrefix": "Context overflow:",
  "suppressTokens": ["HEARTBEAT_OK", "SILENT"],
  "creditMessageTemplate": "Hey! I'm out of credits. You can top up here: {{servicesUrl}}"
}
