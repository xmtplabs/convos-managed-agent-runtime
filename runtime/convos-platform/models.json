{
  "provider": "openrouter",
  "baseUrl": "https://openrouter.ai/api/v1",
  "providerRouting": {
    "only": ["anthropic", "openai", "google-ai-studio", "perplexity"],
    "allowFallbacks": true,
    "_note": "Hermes does not yet wire allowFallbacks to the OpenRouter API call"
  },
  "fallbackModel": "google/gemini-3.1-pro-preview",
  "heartbeatModel": "openai/gpt-5.4-mini",
  "models": [
    { "id": "anthropic/claude-sonnet-4-6",       "name": "Claude Sonnet 4.6",   "input": ["text", "image"], "providerOnly": ["anthropic"] },
    { "id": "anthropic/claude-opus-4-6",         "name": "Claude Opus 4.6",     "input": ["text", "image"], "providerOnly": ["anthropic"] },
    { "id": "google/gemini-3.1-pro-preview",     "name": "Gemini 3 Pro",        "input": ["text", "image"], "providerOnly": ["google-ai-studio"] },
    { "id": "google/gemini-3-flash-preview",     "name": "Gemini 3 Flash",      "input": ["text", "image"], "providerOnly": ["google-ai-studio"] },
    { "id": "openai/gpt-5.4",                   "name": "GPT-5.4",             "input": ["text", "image"], "providerOnly": ["openai"] },
    { "id": "openai/gpt-5.4-mini",              "name": "GPT-5.4 Mini",        "input": ["text", "image"], "providerOnly": ["openai"] },
    { "id": "openai/gpt-oss-20b",               "name": "GPT-OSS 20B",         "input": ["text"],          "providerOnly": ["openai"] },
    { "id": "perplexity/sonar",                  "name": "Perplexity Sonar",    "input": ["text"],          "providerOnly": ["perplexity"] }
  ]
}
