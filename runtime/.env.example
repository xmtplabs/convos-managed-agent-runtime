
# Models
OPENCLAW_PRIMARY_MODEL=openrouter/anthropic/claude-sonnet-4-6

# Runtime
XMTP_ENV=dev                                   # "dev" for staging, "production" for production
OPENCLAW_STATE_DIR=/Users/you/.openclaw         # local state dir (outside Docker)

# Pool provisioning (for local dev with pool API)
POOL_URL=                                       # e.g. http://localhost:3001

# Public URL (optional — used for services page link)
NGROK_URL=                                     # e.g. https://abc123.ngrok.app

# LOCAL ONLY — direct API keys for local development.
# In production, service calls are proxied through the pool manager
# and these keys are NOT needed on the instance.
OPENROUTER_API_KEY=                            # leave blank → pool creates a per-session key
AGENTMAIL_INBOX_ID=                            # leave blank → pool creates an inbox
AGENTMAIL_API_KEY=                              # local dev only — email send/receive
BANKR_API_KEY=                                  # local dev only — crypto wallet
TELNYX_API_KEY=                                 # local dev only — SMS
TELNYX_PHONE_NUMBER=
