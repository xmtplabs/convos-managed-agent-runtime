{
  "name": "convos-agents",
  "version": "0.0.26",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "sh scripts/keys.sh && sh scripts/apply-config.sh && sh scripts/install-deps.sh && sh scripts/identity.sh && sh scripts/gateway.sh",
    "keys": "sh scripts/keys.sh",
    "apply": "sh scripts/apply-config.sh",
    "install-deps": "sh scripts/install-deps.sh",
    "gateway": "sh scripts/gateway.sh",
    "clean-sessions": "sh scripts/clean-sessions.sh",
    "smoke": "sh scripts/smoke.sh",
    "evals": "sh evals/run.sh",
    "evals:knows": "sh evals/run-suite.sh knows.yaml",
    "evals:skills": "sh evals/run-suite.sh skills.yaml",
    "evals:soul": "sh evals/run-suite.sh soul.yaml",
    "evals:convos": "sh evals/run-suite.sh convos.yaml",
    "evals:async": "sh evals/run-suite.sh async.yaml",
    "evals:hermes": "EVAL_RUNTIME=hermes sh evals/run.sh",
    "evals:hermes:knows": "EVAL_RUNTIME=hermes sh evals/run-suite.sh knows.yaml",
    "evals:hermes:skills": "EVAL_RUNTIME=hermes sh evals/run-suite.sh skills.yaml",
    "evals:hermes:soul": "EVAL_RUNTIME=hermes sh evals/run-suite.sh soul.yaml",
    "evals:hermes:convos": "EVAL_RUNTIME=hermes sh evals/run-suite.sh convos.yaml",
    "evals:hermes:async": "EVAL_RUNTIME=hermes sh evals/run-suite.sh async.yaml",
    "ngrok": "ngrok http 18789 --url=c3c882cc6672.ngrok.app",
    "pool-server": "node scripts/pool-server.js",
    "build": "cd .. && docker build -f runtime/Dockerfile -t convos-runtime:local .",
    "docker:run": "cd .. && docker run --rm -p 8080:8080 --env-file runtime/.env -e OPENCLAW_STATE_DIR=/app convos-runtime:local",
    "build:run": "cd .. && docker build -f runtime/Dockerfile -t convos-runtime:local . && docker run --rm -p 8080:8080 --env-file runtime/.env -e OPENCLAW_STATE_DIR=/app convos-runtime:local"
  },
  "dependencies": {
    "@bankr/cli": "^0.1.0",
    "@xmtp/convos-cli": "^0.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "openclaw": "2026.3.11",
    "pg": "^8.18.0"
  }
}
