{
  "name": "convos-assistants",
  "version": "0.3.4",
  "private": true,
  "scripts": {
    "pool-server": "node convos-platform/pool-server/dist/index.js",
    "docker:build:openclaw": "cd .. && docker build -f runtime/openclaw/Dockerfile -t convos-runtime:local .",
    "docker:run:openclaw": "cd .. && docker run --rm -p 8080:8080 --env-file runtime/.env -e OPENCLAW_STATE_DIR=/app convos-runtime:local",
    "docker:build:hermes": "cd .. && docker build -f runtime/hermes/Dockerfile -t convos-runtime-hermes:local .",
    "docker:run:hermes": "cd .. && docker run --rm -p 8080:8080 --env-file runtime/.env convos-runtime-hermes:local",
    "evals": "sh evals/eval.sh"
  }
}
