{
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
    }
  },
  "logging": {
    "consoleLevel": "debug",
    "consoleStyle": "pretty"
  },

  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "browser": {
    "enabled": true,
    "remoteCdpTimeoutMs": 5000,
    "remoteCdpHandshakeTimeoutMs": 8000,
    "defaultProfile": "openclaw",
    "color": "#FF4500",
    "headless": true,
    "noSandbox": true,
    "attachOnly": false,
    "executablePath": "/Applications/Google Chrome.app/Contents/MacOS/Google Chrome",
    "profiles": {
      "openclaw": {
        "cdpPort": 18800,
        "color": "#FF4500"
      }
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.openclaw/workspace",
      "sandbox": { "mode": "off" },
      "blockStreamingDefault": "on",
      "userTimezone": "America/New_York",
    
      "heartbeat": {
        "every": "30m",
        "model": "openrouter/openai/gpt-4o-mini",
        "target": "convos"
      },
      "subagents": {},
      "model": {
        "primary": "${OPENCLAW_PRIMARY_MODEL}"
      },
      "memorySearch": {
        "provider": "openai",
        "model": "openai/text-embedding-3-small",
        "remote": {
          "baseUrl": "https://openrouter.ai/api/v1",
          "apiKey": "${OPENROUTER_API_KEY}"
        },
        "query": {
          "maxResults": 10,
          "hybrid": { "enabled": true }
        }
      }
    }
  },
  "skills": {
    "entries": {
      "services": {
        "enabled": true
      },
      "bankr": {
        "enabled": true
      },
      "settings": {
        "enabled": true
      }
    }
  },
  "channels": {
    "convos": {
      "debug": true,
      "enabled": true,
      "env": "${XMTP_ENV}"
    }
  },
  "tools": {
    "deny": [],
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    },
    "web": {
      "search": {
        "apiKey": "${OPENROUTER_API_KEY}",
        "provider": "perplexity",
        "maxResults": 5,
        "timeoutSeconds": 30,
        "perplexity": {
          "apiKey": "${OPENROUTER_API_KEY}",
          "baseUrl": "https://openrouter.ai/api/v1",
          "model": "perplexity/sonar"
        }
      }
    }
  },
 "plugins": {
    "allow": ["convos", "memory-core", "web-tools"],
    "slots": { "memory": "memory-core" },
    "entries": {
      "convos": { "enabled": true },
      "memory-core": { "enabled": true },
      "web-tools": { "enabled": true }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "${OPENROUTER_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "openai/gpt-oss-20b", "name": "GPT-OSS 20B" },
          { "id": "openai/gpt-5.1-codex-mini", "name": "GPT-5.1 Codex Mini", "input": ["text", "image"] },
          { "id": "perplexity/sonar", "name": "Perplexity Sonar" },
          { "id": "openai/gpt-5.2-codex", "name": "GPT-5.2 Codex", "input": ["text", "image"] },
          { "id": "anthropic/claude-sonnet-4-6", "name": "Claude Sonnet 4.6", "input": ["text", "image"] },
          { "id": "anthropic/claude-opus-4-6", "name": "Claude Opus 4.6", "input": ["text", "image"] },
          { "id": "google/gemini-3-flash-preview", "name": "Gemini 3 Flash", "input": ["text", "image"] },
          { "id": "minimax/minimax-m2.5", "name": "MiniMax M2.5", "input": ["text", "image"] },
          { "id": "moonshotai/kimi-k2.5", "name": "Kimi K2.5", "input": ["text", "image"] },
          { "id": "x-ai/grok-4.1-fast", "name": "Grok 4.1 Fast", "input": ["text", "image"] },
          { "id": "deepseek/deepseek-r1", "name": "DeepSeek R1" },
          { "id": "openai/gpt-4o", "name": "GPT-4o", "input": ["text", "image"] },
          { "id": "openai/gpt-4o-mini", "name": "GPT-4o Mini", "input": ["text", "image"] }
        ]
      }
    }
  }
}
