# Models
OPENCLAW_PRIMARY_MODEL=openrouter/anthropic/claude-sonnet-4-6

# Runtime
XMTP_ENV=dev
PORT=8080

# Pool proxy (set by pool manager in production)
POOL_URL=
INSTANCE_ID=
OPENCLAW_GATEWAY_TOKEN=

# API keys
OPENROUTER_API_KEY=

# Honcho — cross-session user modeling (optional).
# When set, the agent builds a persistent model of each user across conversations.
HONCHO_API_KEY=
