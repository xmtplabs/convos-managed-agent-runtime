POOL_API_URL=http://localhost:3001
NEXT_PUBLIC_POOL_API_URL=http://localhost:3001
NEXT_PUBLIC_POOL_ENVIRONMENT=staging
# Server-side environment guard for pool admin routes (defaults to "production" if unset = fail closed)
POOL_ENVIRONMENT=staging
POOL_API_KEY=<your-pool-api-key>
# Shared secret authenticating POST /api/revalidate calls from the pool.
# Must match DASHBOARD_REVALIDATE_SECRET in the pool env.
REVALIDATE_SECRET=<shared-revalidate-secret>
